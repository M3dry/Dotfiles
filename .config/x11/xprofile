#!/bin/bash

picom &
numlockx on &
xwallpaper --stretch ~/my-stuff/Pictures/wallpapers/dwm-unix.png &
redshift &
dunst &
playerctld &
setxkbmap us,cz ,qwerty -option 'caps:escape' 'grp:ctrls_toggle' &
lxsession &
xrdb .config/x11/xresources &
# /usr/bin/emacs --daemon &
xset r rate 400 50 &
killall dwmStatus ; dwmStatus &
