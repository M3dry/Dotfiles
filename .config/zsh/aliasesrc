alias ll="exa -lar --color=always --group-directories-first"
alias mv="mv -i"
alias rm="rm -i"
alias cp="cp -i"
alias ka="killall"
alias v="nvim"
alias dv="doas nvim"
alias ce="du -a .local/bin | sed 's/.*\t//' | fzf | xargs -r nvim"
alias ..="cd .." 
alias ...="cd ../.."
alias 3.="cd ../../.."
alias p="paru"
alias sudo="doas"
alias mount="doas mount "
alias umount="doas umount "
alias doas="doas --"
alias mks="doas make install"
alias smk="rm config.h && doas make install"
alias te="trash-empty"
alias config='/usr/bin/git --git-dir=$HOME/Dotfiles/ --work-tree=$HOME'
alias cpush='config push git@github.com:M3dry/Dotfiles.git'
alias cstat='config status'
alias ccom='config commit'
alias cadd='config add'
alias doomsync="~/.emacs.d/bin/doom sync"
alias doomupgrade="~/.emacs.d/bin/doom upgrade"
