{
    "languageserver": {
        "ccls": {
            "command": "ccls",
            "diagnostic.refreshOnInsertMode": "true",
            "diagnostic.displayByAle": "true",
            "filetypes": [
                "c",
                "cpp",
                "objc",
                "objcpp",
            ],
            "rootPatterns": [
                ".ccls",
                "compile_commands.json",
                ".vim/",
                ".git/",
                ".hg/"
            ],
            "initializationOptions": {
                "cache": {
                    "directory": "/tmp/ccls"
                },
                "highlight": { "lsRanges" : true }
            }
        }
    }
}
