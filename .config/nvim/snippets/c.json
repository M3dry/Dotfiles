{
    "For": {
        "prefix": ["for"],
        "body": [
            "for (int ${1:i} = ${2:0}; ${3:i} ${4:<} ${5:0}; ${6:i}${7:++}) {",
            "    $0",
            "}"
        ],
        "description": "For loop"
    },
    "While": {
        "prefix": ["while"],
        "body": [
            "while (${1:1}) {",
            "    $0",
            "}"
        ],
        "description": "While loop"
    },
    "Do while": {
        "prefix": ["dowhile"],
        "body": [
            "do {",
            "    $0",
            "} while (${1:1});"
        ],
        "description": "While loop"
    },
    "Switch": {
        "prefix": ["switch"],
        "body": [
            "switch ($1) {",
            "    default:",
            "        $0;",
            "        break;",
            "}"
        ],
        "description": "Switch statement"
    },
    "Case": {
        "prefix": ["case"],
        "body": [
            "case $1:",
            "    $0;",
            "    break;"
        ],
        "description": "Case statement"
    },
    "If": {
        "prefix": ["if"],
        "body": [
            "if (${1:1}) {",
            "    $0",
            "}"
        ],
        "description": "If statement"
    },
    "Function": {
        "prefix": ["fun"],
        "body": [
            "${1:int}",
            "${2}($3)",
            "{",
            "    $0",
            "}"
        ],
        "description": "Function"
    },
    "Main": {
        "prefix": ["main"],
        "body": [
            "int",
            "main(int argc, char **argv)",
            "{",
            "    $0",
            "}"
        ],
        "description": "Main function"
    },
    "Include <>": {
        "prefix": ["inc"],
        "body": [
            "#include <$1"
        ],
        "description": "#include <> statement"
    },
    "Include \"\"": {
        "prefix": ["ins"],
        "body": [
            "#include \"$1"
        ],
        "description": "#include \"\" statement"
    }
}
