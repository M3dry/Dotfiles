#!/bin/sh 

case $BUTTON in
  1) pamixer --toggle-mute;;
  2) $TERMINAL nvim .local/bin/volume;;
  3) st -e pulsemixer;;
  4) $TERMINAL nvim .config/dwmblocks/blocks.h;;
esac

vol="$(pamixer --get-volume)"
[ $(pamixer --get-mute) = true ] && echo 🔇 && exit
[ ${vol} = 0 ] && echo 🔇 && exit

if [ "$vol" -gt "50" ]; then
	icon="🔊"
elif [ "$vol" -lt "10" ]; then
	icon="🔈"
else
	icon="🔉"
fi
echo "$icon $vol%"
