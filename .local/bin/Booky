#!/bin/bash

bookys="$HOME/.config/booky/bookys"
[ -z $3 ] && source $conf || source $HOME/.config/booky/$3

[ -z "$name" ] || embed="-w $(wmctrl -lx | rg "$name" | sed "s/ .*//")" && [ "$embed" = "-w " ] && embd="" || xdo activate -N "$name"

choice=$(rg "$2" "$bookys" | sed "s/$2// ; s/$2.*//" | dmenu -n $embed -l "$lines" -g "$columns" -h "$height" -bw "$border" -fn "$font" -X "$X" -Y "$Y" -W "$width")
[ ! -z $choice ] && $1 $(rg "$2$choice$2" "$bookys" | sed "s/.*$2//;")
