#!/bin/bash

what=$(echo -e "passmenu\ndmenu\nswitch\nvolume\nBooky\nemoji\ncalc\nmanview\ncmusChanger" | dmenu )

[ $what = "passmenu" ] && passmenu2 -F -p "Passwords:"
[ $what = "dmenu" ] && dmenu_run -l 5 -g 10 -p "Run:"
[ $what = "switch" ] && switch
[ $what = "volume" ] && volume-script
[ $what = "Booky" ] && Booky=$(echo -e "bookmarks\nconfigs" | dmenu)
[ $Booky = "bookmarks" ] && Booky "$BROWSER" ":"
[ $Booky = "configs" ] && Booky "$TERMINAL nvim" "><"
[ $what = "emoji" ] && emoji-script
[ $what = "calc" ] && calc
[ $what = "manview" ] && manview
[ $what = "cmusChanger" ] && music-changer cmus
