#!/bin/sh

package() {
    pkg="$(checkupdates | wc -l)"
    [ "$pkg" -gt "100" ] && pkg="^c#ff5370^PKG:$pkg^d^" || pkg="PKG:$pkg"
}

volume() {
    vol="VOL:$(pamixer --get-volume)%"
    [ "$(echo $vol | sed "s/%// ; s/VOL://")" -eq "0" ] && vol="^c#ff5370^MUTED^d^"
    [ "$(echo $vol | sed "s/%// ; s/VOL://")" -ge "50" ] && vol="^c#ffcb6b^$vol^d^"
}

upTime() {
    upt=$(uptime --pretty | sed "s/up // ; s/ days/d/g ; s/ day/d/g ; s/ hours/h/g ; s/ hour/h/g ; s/ minutes/min/g ; s/,//g")
}

memory() {
    mem=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
    memPercentage=$(free -h | awk '/^Mem:/ {print $3/$2 * 100}')
    [ "$(echo $memPercentage | sed "s/\..*//")" -gt "75" ] && mem="^c#ff5370^$mem^d^"
    [ "$(echo $memPercentage | sed "s/\..*//")" -gt "50" ] && mem="^c#f78c6c^$mem^d^"
    [ "$(echo $memPercentage | sed "s/\..*//")" -gt "30" ] && mem="^c#ffcb6b^$mem^d^"
}

clock() {
    date +'%A, %e. %B %H:%M:%S'
}

package
volume
upTime
memory

i=0

while :; do
    dwm -s "[$(clock)] [$pkg] [$vol] [$upt] [$mem] "
    [ "$(($i % 10))" = "0" ] && memory
    [ "$(($i % 120))" = "0" ] && upTime
    [ "$(($i % 25000))" = "0" ] && package
    sleep 0.5
    i=$(($i + 1))
done
