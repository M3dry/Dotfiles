#!/bin/sh

package() {
    pkg=$(checkupdates | wc -l)
}

volume() {
    vol="$(pamixer --get-volume)%"
    case $vol in
        0%) vol="MUTED";;
        *) vol=VOL:$vol;;
    esac
}

upTime() {
upt=$(uptime --pretty | sed "s/up // ; s/ days/d/g ; s/ day/d/g ; s/ hours/h/g ; s/ hour/h/g ; s/ minutes/min/g ; s/,//g")
}

memory() {
    mem=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
}

clock() {
    date +'%A, %e. %B %H:%M:%S'
}

package
volume
upTime
memory

i=0

while :; do
    dwm -s "[$(clock)] [PKG:$pkg] [$vol] [$upt] [$mem] "
    [ "$(($i % 10))" = "0" ] && memory
    [ "$(($i % 120))" = "0" ] && upTime
    [ "$(($i % 25000))" = "0" ] && package
    sleep 0.5
    i=$(($i + 1))
done
